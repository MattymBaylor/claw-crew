# =============================================================================
# Open Claw crew - secrets template
# Copy to `.env` and fill in. NEVER commit the real .env (it is gitignored).
# =============================================================================

# Anthropic API key used by every agent to think/respond.
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# Per-agent Slack credentials.
#
# Each agent is its own Slack app so it gets a real identity and its own DMs.
# For every app create a bot token (xoxb-...) and an app-level token (xapp-...,
# with connections:write for Socket Mode). The env var NAMES below must match
# `bot_token_env` / `app_token_env` in config/roster.yaml.
# -----------------------------------------------------------------------------

ATLAS_BOT_TOKEN=xoxb-...
ATLAS_APP_TOKEN=xapp-...

ECHO_BOT_TOKEN=xoxb-...
ECHO_APP_TOKEN=xapp-...

FORGE_BOT_TOKEN=xoxb-...
FORGE_APP_TOKEN=xapp-...

SAGE_BOT_TOKEN=xoxb-...
SAGE_APP_TOKEN=xapp-...

PROBE_BOT_TOKEN=xoxb-...
PROBE_APP_TOKEN=xapp-...

QUILL_BOT_TOKEN=xoxb-...
QUILL_APP_TOKEN=xapp-...

VAULT_BOT_TOKEN=xoxb-...
VAULT_APP_TOKEN=xapp-...

PULSE_BOT_TOKEN=xoxb-...
PULSE_APP_TOKEN=xapp-...

NOVA_BOT_TOKEN=xoxb-...
NOVA_APP_TOKEN=xapp-...

LEDGER_BOT_TOKEN=xoxb-...
LEDGER_APP_TOKEN=xapp-...

SCOUT_BOT_TOKEN=xoxb-...
SCOUT_APP_TOKEN=xapp-...

MASON_BOT_TOKEN=xoxb-...
MASON_APP_TOKEN=xapp-...

IRIS_BOT_TOKEN=xoxb-...
IRIS_APP_TOKEN=xapp-...

RELAY_BOT_TOKEN=xoxb-...
RELAY_APP_TOKEN=xapp-...

WARDEN_BOT_TOKEN=xoxb-...
WARDEN_APP_TOKEN=xapp-...

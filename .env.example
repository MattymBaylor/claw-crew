# =============================================================================
# Open Claw crew - secrets template
# Copy to `.env` and fill in. NEVER commit the real .env (it is gitignored).
# =============================================================================

# Anthropic API key used by every agent to think/respond.
ANTHROPIC_API_KEY=sk-ant-...

# Only needed for `claw-crew slack-bootstrap` (batch-create apps). Generate at
# api.slack.com/apps -> "Your App Configuration Tokens" -> Generate Token.
# Short-lived (~12h); regenerate when it expires. Leave blank otherwise.
SLACK_CONFIG_TOKEN=xoxe.xoxp-...

# -----------------------------------------------------------------------------
# Per-agent Slack credentials.
#
# Each agent is its own Slack app so it gets a real identity and its own DMs.
# For every app create a bot token (xoxb-...) and an app-level token (xapp-...,
# with connections:write for Socket Mode). The env var NAMES below must match
# `bot_token_env` / `app_token_env` in config/roster.yaml.
# -----------------------------------------------------------------------------

JERRY_BOT_TOKEN=xoxb-...
JERRY_APP_TOKEN=xapp-...

LEO_BOT_TOKEN=xoxb-...
LEO_APP_TOKEN=xapp-...

PUDDY_BOT_TOKEN=xoxb-...
PUDDY_APP_TOKEN=xapp-...

BOOKMAN_BOT_TOKEN=xoxb-...
BOOKMAN_APP_TOKEN=xapp-...

BANIA_BOT_TOKEN=xoxb-...
BANIA_APP_TOKEN=xapp-...

ELAINE_BOT_TOKEN=xoxb-...
ELAINE_APP_TOKEN=xapp-...

SOUPNAZI_BOT_TOKEN=xoxb-...
SOUPNAZI_APP_TOKEN=xapp-...

FRANK_BOT_TOKEN=xoxb-...
FRANK_APP_TOKEN=xapp-...

PETERMAN_BOT_TOKEN=xoxb-...
PETERMAN_APP_TOKEN=xapp-...

GEORGE_BOT_TOKEN=xoxb-...
GEORGE_APP_TOKEN=xapp-...

KRAMER_BOT_TOKEN=xoxb-...
KRAMER_APP_TOKEN=xapp-...

MORTY_BOT_TOKEN=xoxb-...
MORTY_APP_TOKEN=xapp-...

BABU_BOT_TOKEN=xoxb-...
BABU_APP_TOKEN=xapp-...

NEWMAN_BOT_TOKEN=xoxb-...
NEWMAN_APP_TOKEN=xapp-...

JACKIE_BOT_TOKEN=xoxb-...
JACKIE_APP_TOKEN=xapp-...

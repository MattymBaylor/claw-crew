# =============================================================================
# Open Claw crew - secrets template
# Copy to `.env` and fill in. NEVER commit the real .env (it is gitignored).
# =============================================================================

# Anthropic API key used by every agent to think/respond.
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# Per-agent Slack credentials.
#
# Each agent is its own Slack app so it gets a real identity and its own DMs.
# For every app create a bot token (xoxb-...) and an app-level token (xapp-...,
# with connections:write for Socket Mode). The env var NAMES below must match
# `bot_token_env` / `app_token_env` in config/roster.yaml.
# -----------------------------------------------------------------------------

FRANK_BOT_TOKEN=xoxb-...
FRANK_APP_TOKEN=xapp-...

WHATLEY_BOT_TOKEN=xoxb-...
WHATLEY_APP_TOKEN=xapp-...

MICKEY_BOT_TOKEN=xoxb-...
MICKEY_APP_TOKEN=xapp-...

LLOYD_BOT_TOKEN=xoxb-...
LLOYD_APP_TOKEN=xapp-...

DEVOLA_BOT_TOKEN=xoxb-...
DEVOLA_APP_TOKEN=xapp-...

BANIA_BOT_TOKEN=xoxb-...
BANIA_APP_TOKEN=xapp-...

SUEELLEN_BOT_TOKEN=xoxb-...
SUEELLEN_APP_TOKEN=xapp-...

BOOKMAN_BOT_TOKEN=xoxb-...
BOOKMAN_APP_TOKEN=xapp-...

STEINBRENNER_BOT_TOKEN=xoxb-...
STEINBRENNER_APP_TOKEN=xapp-...

UNCLE_LEO_BOT_TOKEN=xoxb-...
UNCLE_LEO_APP_TOKEN=xapp-...
